{
  "name": "assignment/yii2-livestream-api",
  "description": "Livestream backend API with Yii2 and Clean Architecture",
  "type": "project",
  "require": {
    "php": "^8.2",
    "yiisoft/yii2": "^2.0",
    "firebase/php-jwt": "^6.0 || ^7.0 || ^8.0"
  },
  "require-dev": {
    "codeception/codeception": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "",
      "Domain\\": "src/Domain/",
      "Application\\": "src/Application/",
      "Infrastructure\\": "infrastructure/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ]
}
