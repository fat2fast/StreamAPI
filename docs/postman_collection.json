{
  "info": {
    "name": "Yii2 Livestream API",
    "description": "Postman collection for streamer and audience API flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9003"
    },
    {
      "key": "streamer_token",
      "value": ""
    },
    {
      "key": "audience_token",
      "value": ""
    },
    {
      "key": "livestream_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Streamer",
      "item": [
        {
          "name": "Start Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{streamer_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Live coding session\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/streamer/start_room",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "streamer",
                "start_room"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('livestream_id', String(json.data.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Close Room",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{streamer_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/streamer/close_room",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "streamer",
                "close_room"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Audience",
      "item": [
        {
          "name": "List Livestreams",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{audience_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/audience/livestreams",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "audience",
                "livestreams"
              ]
            }
          }
        },
        {
          "name": "Get Livestream Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{audience_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/audience/livestreams/{{livestream_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "audience",
                "livestreams",
                "{{livestream_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
